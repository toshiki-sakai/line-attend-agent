## LINE Messaging API 実装

### Webhook受信

```typescript
// routes/webhook.ts（Hono）

import { Hono } from 'hono';
import type { Env } from '../types';

const webhook = new Hono<{ Bindings: Env }>();

webhook.post('/webhook/:tenantId', async (c) => {
  const tenantId = c.req.param('tenantId');
  const tenant = await getTenant(tenantId, c.env);

  // 1. 署名検証（LINE Channel Secretで）
  const body = await c.req.text();
  const signature = c.req.header('x-line-signature') || '';
  if (!verifySignature(body, signature, tenant.line_channel_secret)) {
    return c.text('Invalid signature', 401);
  }

  // 2. まず200を即返し、重い処理はQueueに投げる（LINE 30秒制限対策）
  const events = JSON.parse(body).events;
  await c.env.MESSAGE_QUEUE.send({
    tenantId,
    events,
  });

  return c.text('OK', 200);
});

export default webhook;
```

### Queue コンシューマー（非同期処理）

```typescript
// services/queue-handler.ts
// LINE Webhookから受け取ったイベントを非同期で処理する
// Cloudflare Queuesのコンシューマーとして動作

export async function handleQueueMessage(batch: MessageBatch<QueuePayload>, env: Env) {
  for (const message of batch.messages) {
    const { tenantId, events } = message.body;
    const tenant = await getTenant(tenantId, env);

    for (const event of events) {
      try {
        switch (event.type) {
          case 'follow':
            // 友だち追加 → ユーザー登録 + シナリオ開始
            await handleFollow(tenant, event, env);
            break;
          case 'message':
            // メッセージ受信 → FlowEngineに渡す
            await handleMessage(tenant, event, env);
            break;
          case 'postback':
            // ボタン押下（予約日程選択等）→ 予約処理
            await handlePostback(tenant, event, env);
            break;
        }
        message.ack();
      } catch (error) {
        console.error(`Event processing failed: ${error}`);
        message.retry();  // 失敗したら自動リトライ
      }
    }
  }
}
```

### 予約日程選択 Flex Message

```typescript
// services/booking.ts

export function buildBookingFlexMessage(slots: AvailableSlot[]): FlexMessage {
  // 空き枠をカルーセル形式のFlex Messageで表示
  // 各枠にpostbackアクション付きのボタンをつける
  // postback data: "book:${slotId}"
  return {
    type: 'flex',
    altText: '日程を選択してください',
    contents: {
      type: 'carousel',
      contents: slots.map(slot => ({
        type: 'bubble',
        body: {
          type: 'box',
          layout: 'vertical',
          contents: [
            { type: 'text', text: formatDate(slot.start_at), weight: 'bold', size: 'lg' },
            { type: 'text', text: `${formatTime(slot.start_at)} 〜 ${formatTime(slot.end_at)}`, size: 'md', color: '#666666' },
            { type: 'text', text: `残り${slot.max_bookings - slot.current_bookings}枠`, size: 'sm', color: '#FF6B6B' }
          ]
        },
        footer: {
          type: 'box',
          layout: 'vertical',
          contents: [
            {
              type: 'button',
              action: { type: 'postback', label: 'この日程で予約する', data: `book:${slot.id}` },
              style: 'primary',
              color: '#4CAF50'
            }
          ]
        }
      }))
    }
  };
}
```


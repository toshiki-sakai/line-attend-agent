## AIガードレール実装

```typescript
// guards/ai-guardrails.ts

interface GuardrailResult {
  passed: boolean;
  violations: string[];
  sanitized_message?: string;
}

export class AIGuardrails {
  private tenant: Tenant;

  // 全テナント共通の禁止パターン
  private static UNIVERSAL_FORBIDDEN = [
    /\d{1,3}[,，]\d{3}円/,          // 金額パターン（例: 300,000円）
    /\d+万円/,                       // 金額パターン（例: 30万円）
    /月額\d+/,                       // 月額パターン
    /絶対[にう]/,                    // 断定表現
    /保証(し|する|します)/,
    /確実[にな]/,
    /必ず[a-zA-Zぁ-ん]/,
    /100\s*[%％]/,
  ];

  /**
   * AI生成メッセージを送信前にチェック
   * 違反があれば再生成を要求、3回失敗したら人間に引き継ぎ
   */
  async validate(message: string): Promise<GuardrailResult> {
    const violations: string[] = [];

    // 1. 全テナント共通チェック
    for (const pattern of AIGuardrails.UNIVERSAL_FORBIDDEN) {
      if (pattern.test(message)) {
        violations.push(`禁止パターン検出: ${pattern.source}`);
      }
    }

    // 2. テナント固有の禁止表現チェック
    for (const expr of this.tenant.guardrail_config.forbidden_expressions) {
      if (message.includes(expr)) {
        violations.push(`テナント禁止表現: ${expr}`);
      }
    }

    // 3. テナント固有の禁止トピックチェック（キーワードベース）
    for (const topic of this.tenant.guardrail_config.forbidden_topics) {
      if (message.includes(topic)) {
        violations.push(`禁止トピック: ${topic}`);
      }
    }

    return {
      passed: violations.length === 0,
      violations,
    };
  }
}
```


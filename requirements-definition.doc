## データベース設計

### テーブル一覧

```sql
-- ============================================
-- テナント（オンラインスクール顧客）
-- ============================================
CREATE TABLE tenants (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  name TEXT NOT NULL,                          -- スクール名
  line_channel_id TEXT NOT NULL UNIQUE,        -- LINE公式アカウントのChannel ID
  line_channel_secret TEXT NOT NULL,           -- Channel Secret
  line_channel_access_token TEXT NOT NULL,     -- Channel Access Token
  scenario_config JSONB NOT NULL DEFAULT '{}', -- シナリオ設定（後述）
  hearing_config JSONB NOT NULL DEFAULT '[]',  -- ヒアリング項目設定
  reminder_config JSONB NOT NULL DEFAULT '{}', -- リマインド設定
  tone_config JSONB NOT NULL DEFAULT '{}',     -- トーン・文言設定
  guardrail_config JSONB NOT NULL DEFAULT '{}',-- 個別ガードレール設定
  school_context TEXT NOT NULL DEFAULT '',     -- スクールの説明（AI用コンテキスト）
  is_active BOOLEAN NOT NULL DEFAULT true,
  created_at TIMESTAMPTZ NOT NULL DEFAULT now(),
  updated_at TIMESTAMPTZ NOT NULL DEFAULT now()
);

-- ============================================
-- エンドユーザー（LINE友だち）
-- ============================================
CREATE TABLE end_users (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  tenant_id UUID NOT NULL REFERENCES tenants(id),
  line_user_id TEXT NOT NULL,                  -- LINE userId
  display_name TEXT,                           -- LINEの表示名
  current_step TEXT NOT NULL DEFAULT 'registered', -- 現在のシナリオステップ
  status TEXT NOT NULL DEFAULT 'active',       -- active / booked / consulted / enrolled / dropped
  hearing_data JSONB NOT NULL DEFAULT '{}',    -- ヒアリング結果
  insight_summary TEXT,                        -- AIが生成したインサイト要約
  follow_up_count INTEGER NOT NULL DEFAULT 0,  -- 追客回数
  last_message_at TIMESTAMPTZ,                 -- 最後にメッセージを送った日時
  last_response_at TIMESTAMPTZ,               -- 最後にユーザーが返信した日時
  source TEXT,                                 -- 流入元（x / youtube / other）
  created_at TIMESTAMPTZ NOT NULL DEFAULT now(),
  updated_at TIMESTAMPTZ NOT NULL DEFAULT now(),
  UNIQUE(tenant_id, line_user_id)
);

-- ============================================
-- 会話ログ
-- ============================================
CREATE TABLE conversations (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  end_user_id UUID NOT NULL REFERENCES end_users(id),
  tenant_id UUID NOT NULL REFERENCES tenants(id),
  role TEXT NOT NULL,                          -- 'user' / 'assistant' / 'system'
  content TEXT NOT NULL,
  message_type TEXT NOT NULL DEFAULT 'text',   -- text / flex / quick_reply
  step_at_time TEXT,                           -- この発言時のシナリオステップ
  created_at TIMESTAMPTZ NOT NULL DEFAULT now()
);

-- ============================================
-- 予約
-- ============================================
CREATE TABLE bookings (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  end_user_id UUID NOT NULL REFERENCES end_users(id),
  tenant_id UUID NOT NULL REFERENCES tenants(id),
  scheduled_at TIMESTAMPTZ NOT NULL,           -- 相談会の日時
  zoom_url TEXT,                               -- ZoomのURL
  status TEXT NOT NULL DEFAULT 'confirmed',    -- confirmed / cancelled / completed / no_show
  reminded_at TIMESTAMPTZ,                     -- 最後にリマインドした日時
  reminder_count INTEGER NOT NULL DEFAULT 0,
  created_at TIMESTAMPTZ NOT NULL DEFAULT now(),
  updated_at TIMESTAMPTZ NOT NULL DEFAULT now()
);

-- ============================================
-- スケジュール枠（顧客が設定する空き枠）
-- ============================================
CREATE TABLE available_slots (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  tenant_id UUID NOT NULL REFERENCES tenants(id),
  start_at TIMESTAMPTZ NOT NULL,
  end_at TIMESTAMPTZ NOT NULL,
  max_bookings INTEGER NOT NULL DEFAULT 1,
  current_bookings INTEGER NOT NULL DEFAULT 0,
  is_active BOOLEAN NOT NULL DEFAULT true,
  created_at TIMESTAMPTZ NOT NULL DEFAULT now()
);

-- ============================================
-- 相談後フォロー
-- ============================================
CREATE TABLE post_consultation_actions (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  booking_id UUID NOT NULL REFERENCES bookings(id),
  tenant_id UUID NOT NULL REFERENCES tenants(id),
  action_type TEXT NOT NULL,                   -- thank_you / enrollment_guide / follow_up / survey
  status TEXT NOT NULL DEFAULT 'pending',      -- pending / sent / completed
  scheduled_at TIMESTAMPTZ NOT NULL,
  content JSONB,                               -- 送信内容（AI生成 or テンプレート）
  created_at TIMESTAMPTZ NOT NULL DEFAULT now()
);

-- インデックス
CREATE INDEX idx_end_users_tenant ON end_users(tenant_id);
CREATE INDEX idx_end_users_status ON end_users(tenant_id, status);
CREATE INDEX idx_end_users_step ON end_users(tenant_id, current_step);
CREATE INDEX idx_conversations_end_user ON conversations(end_user_id);
CREATE INDEX idx_bookings_tenant_status ON bookings(tenant_id, status);
CREATE INDEX idx_bookings_scheduled ON bookings(scheduled_at);
CREATE INDEX idx_available_slots_tenant ON available_slots(tenant_id, start_at);
CREATE INDEX idx_post_consultation_booking ON post_consultation_actions(booking_id);
```


## スケジューラ設計

```typescript
// services/scheduler.ts
// Cloudflare Cron Triggers で実行される定期処理
// wrangler.toml の [triggers] で cron = ["* * * * *"]（毎分）を設定

export async function handleScheduled(
  controller: ScheduledController,
  env: Env
) {
  const now = new Date(controller.scheduledTime);

  await Promise.all([
    processDelayedSteps(env, now),     // delay待ちのシナリオステップ
    processReminders(env, now),        // 予約リマインド
    processFollowUps(env, now),        // 追客メッセージ
    processPostConsultation(env, now), // 相談後フォロー
  ]);
}
}

async function processReminders() {
  // 1. 3日前・前日・1時間前のリマインド対象bookingを取得
  // 2. テナントのreminder設定に従い、templateまたはAIでメッセージ生成
  // 3. 送信 + reminded_at更新
  // 4. ノーショー検知（予約時間を過ぎてstatus=confirmedのまま → no_showに変更 + フォロー）
}

async function processFollowUps() {
  // 1. status=active かつ last_response_at が一定時間以上前のユーザーを取得
  // 2. follow_up_count < max_attempts のユーザーのみ対象
  // 3. AI判断モードの場合はClaude APIに「今送るべきか？」を判断させる
  // 4. 送信 + follow_up_countインクリメント
}
```


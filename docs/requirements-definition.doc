## スケジューラ

```typescript
// services/scheduler.ts
export async function handleScheduled(controller: ScheduledController, env: Env, ctx: ExecutionContext) {
  await Promise.allSettled([
    processScheduledActions(env), // lock_pending_actions RPC → 実行 → completed/retry
    detectNoShows(env),           // 予約時刻+30分 → no_show → フォロー登録
  ]);
}
// 排他制御: Supabase RPC lock_pending_actions() で FOR UPDATE SKIP LOCKED
```


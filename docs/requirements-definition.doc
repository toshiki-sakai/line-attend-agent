### 予約（楽観的ロック）

```typescript
// services/booking.ts
// available_slots.version で楽観的ロック → 同時予約の競合防止
async function incrementSlotBooking(slotId: string, expectedVersion: number, env: Env): Promise<boolean> {
  const { data } = await supabase(env).from('available_slots')
    .update({ current_bookings: sql`current_bookings + 1`, version: expectedVersion + 1 })
    .eq('id', slotId).eq('version', expectedVersion).select();
  return data && data.length > 0;
}
```


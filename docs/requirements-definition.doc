## LINE実装

### Webhook + Queue

```typescript
// routes/webhook.ts
webhook.post('/webhook/:tenantId', async (c) => {
  const tenant = await getTenant(c.req.param('tenantId'), c.env);
  if (!tenant?.is_active) return c.text('Not found', 404);
  const body = await c.req.text();
  if (!verifySignature(body, c.req.header('x-line-signature') || '', tenant.line_channel_secret)) {
    return c.text('Invalid signature', 401);
  }
  const events = JSON.parse(body).events || [];
  if (events.length > 0) {
    await c.env.MESSAGE_QUEUE.send({ tenantId: tenant.id, events, receivedAt: new Date().toISOString() });
  }
  return c.text('OK', 200);
});

// services/queue-handler.ts — 冪等性保証付き
export async function handleQueueMessage(batch: MessageBatch<QueuePayload>, env: Env) {
  for (const message of batch.messages) {
    try {
      for (const event of message.body.events) {
        const eventId = `${event.source.userId}-${event.timestamp}`;
        if (await isAlreadyProcessed(eventId, env)) continue;
        switch (event.type) {
          case 'follow': await handleFollow(/*...*/); break;
          case 'unfollow': await handleUnfollow(/*...*/); break; // ★ ブロック処理
          case 'message': await handleMessage(/*...*/); break;
          case 'postback': await handlePostback(/*...*/); break;
        }
        await markProcessed(eventId, env);
      }
      message.ack();
    } catch (error) { message.retry(); }
  }
}
```

